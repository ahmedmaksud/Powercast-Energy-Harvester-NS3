        <mxCell id="efficiency-title" value="&lt;b&gt;RF-DC Efficiency Curve&lt;/b&gt;&lt;br&gt;P21XXCSR-EVB Band 6" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1095" y="442" width="200" height="35" as="geometry" />
        </mxCell>
        <mxCell id="wifi-note" value="&lt;b&gt;Typical WiFi Scenario:&lt;/b&gt;&lt;br&gt;RX Power: -30 to -10 dBm&lt;br&gt;Efficiency: 10% - 40%" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="1030" y="762" width="330" height="50" as="geometry" />
        </mxCell>
        <mxCell id="formulas-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="1220" y="30" width="200" height="380" as="geometry" />
        </mxCell>
        <mxCell id="formulas-title" value="&lt;b&gt;Key Equations&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=14;" parent="1" vertex="1">
          <mxGeometry x="1260" y="25" width="120" height="25" as="geometry" />
        </mxCell>
        <mxCell id="formula1" value="&lt;b&gt;Capacitor Energy:&lt;/b&gt;&lt;br&gt;E = ½CV²" style="text;html=1;strokeColor=none;fillColor=#e6f2ff;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="1235" y="55" width="170" height="40" as="geometry" />
        </mxCell>
        <mxCell id="formula2" value="&lt;b&gt;Harvested Energy:&lt;/b&gt;&lt;br&gt;E_h = P_rx × η × η_boost × t" style="text;html=1;strokeColor=none;fillColor=#e6ffe6;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="1235" y="105" width="170" height="45" as="geometry" />
        </mxCell>
        <mxCell id="formula3" value="&lt;b&gt;TX Energy Required:&lt;/b&gt;&lt;br&gt;E_tx = P_tx × t / η_PA" style="text;html=1;strokeColor=none;fillColor=#ffe6e6;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="1235" y="160" width="170" height="45" as="geometry" />
        </mxCell>
        <mxCell id="formula4" value="&lt;b&gt;Available Energy:&lt;/b&gt;&lt;br&gt;E_avail = E_nom - E_sunk" style="text;html=1;strokeColor=none;fillColor=#fff2e6;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="1235" y="215" width="170" height="45" as="geometry" />
        </mxCell>
        <mxCell id="formula5" value="&lt;b&gt;Voltage from Energy:&lt;/b&gt;&lt;br&gt;V = √(2E/C)" style="text;html=1;strokeColor=none;fillColor=#f2e6ff;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="1235" y="270" width="170" height="40" as="geometry" />
        </mxCell>
        <mxCell id="constants" value="&lt;b&gt;Constants:&lt;/b&gt;&lt;br&gt;η_boost = 90%&lt;br&gt;η_PA = 90%&lt;br&gt;DEEP_RATIO = 50%&lt;br&gt;SHOOT_RATIO = 150%" style="text;html=1;strokeColor=none;fillColor=#e6e6e6;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="1235" y="320" width="170" height="70" as="geometry" />
        </mxCell>
