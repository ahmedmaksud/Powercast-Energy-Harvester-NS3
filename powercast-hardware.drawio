        <mxCell id="pretx-title" value="&lt;b&gt;3. Pre-Transmission Validation&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="615" y="645.5" width="230" height="20" as="geometry" />
        </mxCell>
        <mxCell id="pretx-desc" value="&lt;font size=&quot;1&quot;&gt;• Checks E_avail ≥ E_required before TX&lt;br&gt;• Blocks transmission if insufficient energy&lt;br&gt;• Prevents loss of transmission midway&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;" parent="1" vertex="1">
