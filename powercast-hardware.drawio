          <mxGeometry x="615" y="560.5" width="230" height="20" as="geometry" />
        </mxCell>
        <mxCell id="overshoot-desc" value="&lt;font size=&quot;1&quot;&gt;• SHOOT_RATIO = 150% of Vmax&lt;br&gt;• Voltage clamped at V_shoot maximum&lt;br&gt;• Prevents capacitor over-voltage damage&lt;br&gt;&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;" parent="1" vertex="1">
