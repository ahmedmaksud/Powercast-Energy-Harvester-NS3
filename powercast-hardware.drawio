        <mxCell id="output-desc" value="&lt;font size=&quot;1&quot;&gt;• Vcap ≥ 80% × Vmin for output enable&lt;br&gt;• Hysteresis between Vmin and Vmax&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;" parent="1" vertex="1">
