        </mxCell>
        <mxCell id="deep-desc" value="&lt;font size=&quot;1&quot;&gt;• DEEP_RATIO = 50% of Vmin&lt;br&gt;• Prevents capacitor damage from over-discharge&lt;br&gt;• E_sunk reserves energy below V_deep&lt;br&gt;&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;" parent="1" vertex="1">
